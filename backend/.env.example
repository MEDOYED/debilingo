# ==========================================
# Debilingo Backend - Environment Variables
# ==========================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values (see instructions below)
# 3. Never commit the .env file to Git
# ------------------------------------------
# Server Configuration
# ------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:1414
JWT_SECRET=change_this_to_a_random_secure_string_min_32_chars
# ------------------------------------------
# Supabase Configuration
# ------------------------------------------
# You need to create your own Supabase project (free tier is enough)
# 
# Steps:
# 1. Go to https://supabase.com and create account
# 2. Click "New Project"
# 3. After project is created, go to Settings > API
# 4. Copy "Project URL" and paste below as SUPABASE_URL
# 5. Copy "anon/public" key and paste below as SUPABASE_ANON_KEY
# 6. Then run the database schema from docs/database-schema.sql
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here