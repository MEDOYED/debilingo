# ==========================================
# Debilingo Frontend - Environment Variables
# ==========================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env (or create .env and write there VITE_API_URL=https://debilingo-backend-dev-423439214783.us-central1.run.app/api if you only frontend developer )
# 2. Choose one of the options below
# ------------------------------------------
# Option A: Frontend-Only Development (RECOMMENDED for beginners)
# ------------------------------------------
# Use this if you only work on the frontend and don't need to run backend locally.
# This connects to the deployed development backend with a real database.
VITE_API_URL=https://debilingo-backend-dev-423439214783.us-central1.run.app/api
# ------------------------------------------
# Option B: Full-Stack Development
# ------------------------------------------
# Use this if you're running the backend locally on your machine.
# Uncomment the line below and comment out Option A.
# VITE_API_URL=http://localhost:3001/api
